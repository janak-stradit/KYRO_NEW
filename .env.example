# ============================================================
# KYRO AML Pipeline — Environment Variables Template
# Copy to .env and fill in production values before deploying.
# NEVER commit .env with real credentials to source control.
# ============================================================

# ── Application ───────────────────────────────────────────────
PIPELINE_ENV=development          # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
NUM_CUSTOMERS=200                 # Records to generate per pipeline run
PORT=5050                         # Flask API port

# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kyro_aml
DB_USER=kyro_user
DB_PASSWORD=kyro_pass             # CHANGE IN PRODUCTION
DB_SSL_MODE=prefer                # disable | prefer | require | verify-full

# ── pgAdmin ───────────────────────────────────────────────────
PGADMIN_PASSWORD=admin123         # CHANGE IN PRODUCTION

# ── Flask ─────────────────────────────────────────────────────
FLASK_APP=generator_service.py
FLASK_ENV=development
PYTHONPATH=.

# ── Pipeline behaviour ────────────────────────────────────────
PIPELINE_BATCH_SIZE=5000
PIPELINE_MAX_RETRIES=3
PIPELINE_RETRY_DELAY=5

# ── Risk Assessment API (app/) ───────────────────────────────
APP_NAME=KYRO Risk Assessment
DEBUG=False
API_PORT=8000
API_HOST_PORT=8010                     # host-side port; change if 8000 is taken on the host
DATABASE_URL=postgresql+psycopg://kyro_user:kyro_pass@localhost:5434/kyro_aml
REDIS_URL=redis://localhost:6380/0     # host port; containers reach Redis at redis:6379 internally
REDIS_HOST_PORT=6380                   # change if 6380 is also taken on the host
SECRET_KEY=change-me-in-production   # CHANGE IN PRODUCTION — use `openssl rand -hex 32`
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── ML Engine (Phase 2) ───────────────────────────────────────
MODEL_REGISTRY_PATH=./models
RETRAIN_THRESHOLD=1000
PERFORMANCE_THRESHOLD=0.85
TRAINING_DATA_DAYS=365
SHAP_EXPLANATION_TOP_K=5

# ── ElevenLabs TTS ────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here
ELEVENLABS_MODEL_ID=eleven_turbo_v2
TTS_PROVIDER=elevenlabs

